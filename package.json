{
  "name": "insightdisc",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:setup": "./setup-dev.sh",
    "build": "vite build",
    "lint": "eslint . --quiet",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc -p ./jsconfig.json",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "test:unit:ai": "node --test tests/unit/ai-disc-*.test.js",
    "test:unit:disc-engine": "node --test tests/unit/disc-engine.test.js",
    "test:smoke": "playwright test tests/e2e/smoke.spec.js",
    "test:public-report": "playwright test tests/e2e/public-report.spec.js",
    "test:portal-claim": "playwright test tests/e2e/portal-claim.spec.js",
    "test:job-matching": "playwright test tests/e2e/job-matching.spec.js",
    "test:super-admin": "playwright test tests/e2e/super-admin.spec.js",
    "test:report:local": "node scripts/test-report-generate.mjs",
    "test:leads": "playwright test tests/e2e/leads-dashboard.spec.js",
    "test:auth-live": "playwright test tests/e2e/auth-access-live.spec.js --config=playwright.live.config.js",
    "preview": "vite preview",
    "report:sample": "node reporting/generatePdf.js reporting/sample-data.json",
    "report:build": "node reporting/generatePdf.js",
    "report:smoke": "node reporting/smoke.js",
    "disc:personal": "cd public/relatorio_teste && node disc_engine.js --mode=personal && node gerar_pdf.mjs relatorio_disc_personal.html relatorio_disc_personal.pdf",
    "disc:professional": "cd public/relatorio_teste && node disc_engine.js --mode=professional && node gerar_pdf.mjs relatorio_disc_professional.html relatorio_disc_professional.pdf",
    "disc:business": "cd public/relatorio_teste && node disc_engine.js --mode=business && node gerar_pdf.mjs relatorio_disc_business.html relatorio_disc_business.pdf",
    "disc:all": "cd public/relatorio_teste && ./gerar_todos.sh",
    "smoke:invite": "node scripts/smoke-invite-flow.mjs",
    "seed:super-admin": "node server/scripts/seed-super-admin.js"
  },
