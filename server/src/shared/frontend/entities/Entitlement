{
  "name": "Entitlement",
  "type": "object",
  "properties": {
    "tenant_id": {
      "type": "string"
    },
    "user_id": {
      "type": "string"
    },
    "key": {
      "type": "string",
      "description": "Ex.: report.pro, report.export.pdf"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "revoked",
        "expired"
      ],
      "default": "active"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "granted_by_user_id": {
      "type": "string"
    }
  },
  "required": [
    "key",
    "status"
  ]
}

