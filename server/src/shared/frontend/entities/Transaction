{
  "name": "Transaction",
  "type": "object",
  "properties": {
    "user_id": {
      "type": "string"
    },
    "workspace_id": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "purchase",
        "subscription",
        "credit_pack",
        "refund"
      ],
      "description": "Tipo de transa\u00e7\u00e3o"
    },
    "product": {
      "type": "string",
      "enum": [
        "premium_report",
        "credits_10",
        "credits_50",
        "credits_100",
        "plan_pro",
        "plan_enterprise"
      ],
      "description": "Produto adquirido"
    },
    "amount": {
      "type": "number",
      "description": "Valor em centavos"
    },
    "currency": {
      "type": "string",
      "default": "BRL"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "completed",
        "failed",
        "refunded"
      ],
      "default": "pending"
    },
    "payment_method": {
      "type": "string",
      "enum": [
        "pix",
        "credit_card",
        "boleto",
        "apple_pay",
        "google_pay"
      ]
    },
    "payment_gateway": {
      "type": "string"
    },
    "gateway_transaction_id": {
      "type": "string"
    },
    "credits_added": {
      "type": "number",
      "description": "Cr\u00e9ditos adicionados (se aplic\u00e1vel)"
    },
    "metadata": {
      "type": "object"
    }
  },
  "required": [
    "user_id",
    "type",
    "amount"
  ]
}
